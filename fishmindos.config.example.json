{
  "llm": {
    "provider": "zhipu",
    "api_key": "replace-with-your-api-key",
    "base_url": null,
    "model": "glm-4.5-air",
    "temperature": 0.2,
    "max_tokens": 2000,
    "timeout": 30
  },
  "nav_server": {
    "host": "127.0.0.1",
    "port": 9001
  },
  "nav_app": {
    "host": "127.0.0.1",
    "port": 9002
  },
  "rosbridge": {
    "host": "127.0.0.1",
    "port": 9090,
    "path": "/api/rt",
    "use_ssl": false
  },
  "websocket": {
    "enabled": true,
    "reconnect_interval": 5,
    "max_reconnect_attempts": 10,
    "ping_interval": 30
  },
  "callback": {
    "enabled": false,
    "host": "0.0.0.0",
    "port": 8081,
    "path": "/callback/nav_event",
    "url": null,
    "max_events": 100
  },
  "world": {
    "enabled": true,
    "path": "fishmindos/world/semantic_map.json",
    "auto_switch_map": true,
    "prefer_current_map": true,
    "adapter_fallback": false
  },
  "soul": {
    "enabled": true,
    "path": "fishmindos/soul/soul.json",
    "max_memories": 200
  },
  "mission": {
    "wait_confirm_reminder_enabled": true,
    "wait_confirm_reminder_interval_sec": 20,
    "wait_confirm_reminder_text": "请确认后我再继续执行。"
  },
  "skills": {
    "search_paths": [
      "skill_store",
      "skills",
      "custom_skills"
    ],
    "hot_reload": false,
    "auto_discover": true
  },
  "app": {
    "debug": false,
    "log_level": "INFO",
    "identity": "你的机器人名字",
    "prompt_profile": null,
    "language": "zh"
  }
}
